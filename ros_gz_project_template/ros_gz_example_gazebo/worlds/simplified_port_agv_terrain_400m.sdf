<?xml version="1.0" ?>
<!--
  Simplified Port AGV Terrain World (400 m × 400 m)

  Purpose:
    A minimal, repeatable Gazebo experiment scene for the current
    agv_ackermann + /agv/* runtime path. It is intentionally not a full port.

  Design constraints:
    - Keep the existing primary vehicle: agv_ackermann
    - Reuse only existing port-semantic assets:
        ground_plane, port_crane, container_single, container_stack
    - Preserve /agv/cmd_vel, /agv/odometry and the current ros_gz bridge chain
    - Keep world name "demo" so the existing bridge config remains valid

  Experiment layout:
    - Main corridor:      (-120, 10)   -> (120, 10),  width 12 m
    - Secondary corridor: (-120, -40)  -> (120, -40), width 12 m
    - Connector lane:     (120, 10) -> (120, -40) -> (-120, -40)

  Deformation zones:
    Zone A / B / C are exposed in a sibling YAML parameter file and now map to
    a dedicated physical terrain tile inside the test corridor band. The
    markers remain as visual aids, but the AGV now contacts the terrain mesh
    rather than a single flat apron collision inside that area.
-->
<sdf version="1.8">
  <world name="demo">

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>50</iters>
          <sor>1.3</sor>
        </solver>
        <constraints>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>10.0</contact_max_correcting_vel>
          <contact_surface_layer>0.001</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <plugin
      filename="ignition-gazebo-physics-system"
      name="ignition::gazebo::systems::Physics">
    </plugin>

    <plugin
      filename="ignition-gazebo-sensors-system"
      name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <plugin
      filename="ignition-gazebo-scene-broadcaster-system"
      name="ignition::gazebo::systems::SceneBroadcaster">
    </plugin>

    <plugin
      filename="ignition-gazebo-user-commands-system"
      name="ignition::gazebo::systems::UserCommands">
    </plugin>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!--
      Segmented 400 m × 400 m operating apron.
      The central experiment band is intentionally cut out of this flat ground
      so the dedicated terrain mesh below becomes the active collision surface
      for Zone A / B / C instead of being shadowed by a planar ground collision.
    -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="top_strip_collision">
          <pose>0 109 -0.1 0 0 0</pose>
          <geometry>
            <box>
              <size>400 182 0.2</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>100</kd>
                <max_vel>0.1</max_vel>
                <min_depth>0.001</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
        <collision name="bottom_strip_collision">
          <pose>0 -123 -0.1 0 0 0</pose>
          <geometry>
            <box>
              <size>400 154 0.2</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>100</kd>
                <max_vel>0.1</max_vel>
                <min_depth>0.001</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
        <collision name="left_strip_collision">
          <pose>-163 -14 -0.1 0 0 0</pose>
          <geometry>
            <box>
              <size>74 64 0.2</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>100</kd>
                <max_vel>0.1</max_vel>
                <min_depth>0.001</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
        <collision name="right_strip_collision">
          <pose>163 -14 -0.1 0 0 0</pose>
          <geometry>
            <box>
              <size>74 64 0.2</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>100</kd>
                <max_vel>0.1</max_vel>
                <min_depth>0.001</min_depth>
              </ode>
            </contact>
          </surface>
        </collision>
        <visual name="top_strip_visual">
          <pose>0 109 0 0 0 0</pose>
          <geometry>
            <box>
              <size>400 182 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0.50 0.50 0.50 1</ambient>
            <diffuse>0.60 0.60 0.60 1</diffuse>
            <specular>0.40 0.40 0.40 1</specular>
          </material>
        </visual>
        <visual name="bottom_strip_visual">
          <pose>0 -123 0 0 0 0</pose>
          <geometry>
            <box>
              <size>400 154 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0.50 0.50 0.50 1</ambient>
            <diffuse>0.60 0.60 0.60 1</diffuse>
            <specular>0.40 0.40 0.40 1</specular>
          </material>
        </visual>
        <visual name="left_strip_visual">
          <pose>-163 -14 0 0 0 0</pose>
          <geometry>
            <box>
              <size>74 64 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0.50 0.50 0.50 1</ambient>
            <diffuse>0.60 0.60 0.60 1</diffuse>
            <specular>0.40 0.40 0.40 1</specular>
          </material>
        </visual>
        <visual name="right_strip_visual">
          <pose>163 -14 0 0 0 0</pose>
          <geometry>
            <box>
              <size>74 64 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0.50 0.50 0.50 1</ambient>
            <diffuse>0.60 0.60 0.60 1</diffuse>
            <specular>0.40 0.40 0.40 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!--
      Unified physical terrain for the active test band.
      Dartsim currently does not construct mesh / heightmap collision directly
      from SDF in this stack, so the runtime collision surface is tessellated
      into thin primitive boxes while the visual stays a lightweight mesh.
      Zone A / B / C heights are still driven by the same shared terrain profile.
    -->
