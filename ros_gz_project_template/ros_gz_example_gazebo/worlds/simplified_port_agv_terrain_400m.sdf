        <visual name="terrain_visual">
          <cast_shadows>false</cast_shadows>
          <geometry>
            <mesh>
              <uri>meshes/test_corridor_terrain.obj</uri>
            </mesh>
          </geometry>
          <material>
            <lighting>false</lighting>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
            <ambient>0.50 0.50 0.50 1</ambient>
            <diffuse>0.60 0.60 0.60 1</diffuse>
            <specular>0.40 0.40 0.40 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Corridor overlays: visual-only markers for repeatable experiment paths -->
    <model name="main_test_corridor_overlay">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <pose>0 10 0.005 0 0 0</pose>
          <geometry>
            <box><size>240 12 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.10 0.18 0.26 0.70</ambient>
            <diffuse>0.12 0.22 0.34 0.70</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="secondary_test_corridor_overlay">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <pose>0 -40 0.005 0 0 0</pose>
          <geometry>
            <box><size>240 12 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.10 0.18 0.26 0.70</ambient>
            <diffuse>0.12 0.22 0.34 0.70</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="connector_test_corridor_overlay">
      <static>true</static>
      <link name="link">
        <visual name="vertical_leg">
          <pose>120 -15 0.005 0 0 0</pose>
          <geometry>
            <box><size>12 50 0.01</size></box>
          </geometry>
          <material>
            <ambient>0.10 0.18 0.26 0.70</ambient>
            <diffuse>0.12 0.22 0.34 0.70</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Deformation zone markers: visual aids layered on top of the real terrain mesh -->
    <model name="zone_a_uniform_settlement_marker">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <pose>-20 10 0.01 0 0 0</pose>
          <geometry>
            <box><size>40 14 0.02</size></box>
          </geometry>
          <material>
            <ambient>0.00 0.35 0.85 0.55</ambient>
            <diffuse>0.05 0.45 0.95 0.55</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="zone_b_differential_slope_marker">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <pose>35 10 0.01 0 0 0</pose>
          <geometry>
            <box><size>50 14 0.02</size></box>
          </geometry>
          <material>
            <ambient>0.95 0.55 0.05 0.55</ambient>
            <diffuse>0.98 0.62 0.08 0.55</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="zone_c_local_trap_marker">
      <static>true</static>
      <link name="link">
        <visual name="visual">
          <pose>0 -40 0.015 0 0 0</pose>
          <geometry>
            <cylinder><radius>2</radius><length>0.03</length></cylinder>
          </geometry>
          <material>
            <ambient>0.80 0.10 0.10 0.65</ambient>
            <diffuse>0.90 0.15 0.15 0.65</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Primary vehicle: unchanged agv_ackermann model and /agv/* bridge contract -->
    <model name="agv_ackermann">
      <self_collide>false</self_collide>
      <pose>20 12 0.58 0 0 0</pose>

      <include merge="true">
        <uri>package://ros_gz_example_description/models/agv_ackermann</uri>
      </include>

      <plugin
        filename="ignition-gazebo-joint-state-publisher-system"
        name="ignition::gazebo::systems::JointStatePublisher">
      </plugin>

      <plugin
        filename="ignition-gazebo-pose-publisher-system"
        name="ignition::gazebo::systems::PosePublisher">
        <publish_link_pose>true</publish_link_pose>
        <use_pose_vector_msg>true</use_pose_vector_msg>
        <static_publisher>true</static_publisher>
        <static_update_frequency>10</static_update_frequency>
      </plugin>
    </model>

    <!-- Existing static landmarks / obstacles kept at user-provided poses -->
    <include>
      <uri>package://harbour_assets_description/models/crane1</uri>
      <name>port_crane</name>
      <pose>-60 32 0 0 0 0</pose>
    </include>

    <!--
      Container yard blocks (B1~B8), lightweight replacement.
      This grouped static model keeps the original 16 yard_block_* footprints
      while removing 16 container40 mesh includes from the startup path.
      Each box below approximates one 40 ft container with primitive visual and
      collision geometry placed at the same world-space occupancy as the old
      container40 include (including the original mesh offset compensation).

      Visual refresh: keep primitive boxes, but reuse two weathered container
      side textures from harbour_assets_description so the yard still reads as
      stacked single boxes without bringing the original mesh instances back.
    -->
    <model name="yard_blocks_group">
      <static>true</static>
      <link name="link">
        <visual name="b1_upper_visual">
          <pose>-71.214 -1.908 1.296 0 0 1.57</pose>
          <geometry><box><size>12.201 2.439 2.591</size></box></geometry>
          <material>
            <ambient>0.80 0.80 0.80 1</ambient>
            <diffuse>1.00 1.00 1.00 1</diffuse>
            <specular>0.12 0.12 0.12 1</specular>
            <pbr>
              <metal>
                <albedo_map>model://container-multi-stack/containerstack1/F.ST._txt_Metall_container_1.jpg</albedo_map>
                <roughness>0.82</roughness>
                <metalness>0.12</metalness>
              </metal>
            </pbr>
          </material>
        </visual>
        <collision name="b1_upper_collision">
          <pose>-71.214 -1.908 1.296 0 0 1.57</pose>
          <geometry><box><size>12.201 2.439 2.591</size></box></geometry>
        </collision>

        <visual name="b1_lower_visual">
          <pose>-71.214 -15.908 1.296 0 0 1.57</pose>
          <geometry><box><size>12.201 2.439 2.591</size></box></geometry>
          <material>
            <ambient>0.84 0.84 0.84 1</ambient>
            <diffuse>1.00 1.00 1.00 1</diffuse>
            <specular>0.12 0.12 0.12 1</specular>
            <pbr>
              <metal>
                <albedo_map>model://container-multi-stack/containerstack1/F.ST._txt_Metall_container_1.1.jpg</albedo_map>
                <roughness>0.80</roughness>
                <metalness>0.12</metalness>
              </metal>
            </pbr>
          </material>
        </visual>
        <collision name="b1_lower_collision">
          <pose>-71.214 -15.908 1.296 0 0 1.57</pose>
          <geometry><box><size>12.201 2.439 2.591</size></box></geometry>
        </collision>

        <visual name="b2_upper_visual">
          <pose>-55.214 -1.908 1.296 0 0 1.57</pose>
          <geometry><box><size>12.201 2.439 2.591</size></box></geometry>
          <material>
            <ambient>0.76 0.76 0.76 1</ambient>
            <diffuse>1.00 1.00 1.00 1</diffuse>
            <specular>0.10 0.10 0.10 1</specular>
